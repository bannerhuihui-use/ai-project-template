# ===================================================================
# Admin 前端环境变量说明（可提交仓库）
#
# Vite 按 mode 自动加载，无需手动 cp 成 .env：
#   npm run dev   → .env.development（+ .env.local 可选覆盖）
#   npm run build → .env.production（+ .env.local 可选覆盖）
#
# 已内置：.env.development / .env.production
# 个人机器差异（如后端不在 8080）：新建 .env.local 覆盖，勿改 committed 文件
# ===================================================================

# ---------- 开发（.env.development）----------
# VITE_API_BASE_URL=/api
# VITE_PROXY_TARGET=http://localhost:8080
# VITE_TOKEN_STORAGE=local

# ---------- 生产（.env.production）----------
# VITE_API_BASE_URL=/api
# VITE_TOKEN_STORAGE=local

# ---------- 个人覆盖（.env.local，gitignore）----------
# VITE_PROXY_TARGET=http://192.168.1.10:8080

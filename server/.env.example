# ===================================================================
# 环境配置示例（可提交到仓库）
# 复制为 .env 后填写真实值；.env 已在 .gitignore 中忽略，不会被提交
# yml 通过 ${KEY} 引用本文件的值；用到某项时取消对应注释并填写
# 注意：值含 # 等特殊字符时，必须用【双引号】包裹（如 PWD="a#b"）；
#       不要用单引号（dotenv-java 不会去掉单引号），不加引号则 # 之后会被当注释截断。
# ===================================================================

# ---------- 基础 ----------
# 环境：local / test / prod
SPRING_PROFILES_ACTIVE=local
SERVER_PORT=8080
APP_NAME=template-server

# ---------- MySQL ----------
# MYSQL_HOST=localhost
# MYSQL_PORT=3306
# MYSQL_DATABASE=template_db
# MYSQL_USERNAME=root
# MYSQL_PASSWORD=

# ---------- PostgreSQL ----------
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_DATABASE=template_db
# POSTGRES_USERNAME=postgres
# POSTGRES_PASSWORD=

# ---------- MongoDB ----------
# MONGODB_HOST=localhost
# MONGODB_PORT=27017
# MONGODB_DATABASE=template_db
# MONGODB_USERNAME=
# MONGODB_PASSWORD=
# MONGODB_AUTH_DB=admin

# ---------- Redis ----------
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_DATABASE=0

# ---------- RabbitMQ ----------
# RABBITMQ_HOST=localhost
# RABBITMQ_PORT=5672
# RABBITMQ_USERNAME=guest
# RABBITMQ_PASSWORD=guest
# RABBITMQ_VHOST=/

# ---------- 阿里云 OSS ----------
# OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
# OSS_ACCESS_KEY_ID=
# OSS_ACCESS_KEY_SECRET=
# OSS_BUCKET=

# ---------- 火山引擎 方舟大模型 ----------
# VOLC_ARK_API_KEY=
# VOLC_ARK_MODEL=
# VOLC_ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# ---------- 短信 ----------
# SMS_ACCESS_KEY_ID=
# SMS_ACCESS_KEY_SECRET=
# SMS_SIGN_NAME=
# SMS_TEMPLATE_CODE=

# ---------- 邮箱 ----------
# MAIL_HOST=smtp.example.com
# MAIL_PORT=465
# MAIL_USERNAME=
# MAIL_PASSWORD=
